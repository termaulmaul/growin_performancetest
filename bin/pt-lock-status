#!/usr/bin/env python3
"""Fast status bar string. Called every banner render. Must be < 50ms."""
import sys, os, json

sys.path.append(os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'lib', 'python'))
from db import get_conn
from datetime import datetime, timezone

def main():
    current_user = sys.argv[1] if len(sys.argv) > 1 else "?"
    env = sys.argv[2] if len(sys.argv) > 2 else None
    
    try:
        conn = get_conn()
        if env:
            rows = conn.execute("SELECT * FROM locks WHERE env=? AND status='active'", (env,)).fetchall()
        else:
            rows = conn.execute("SELECT * FROM locks WHERE status='active'").fetchall()
    except Exception:
        print(f"🟢 Available | {current_user} [Idle]")
        return

    if not rows:
        print(f"🟢 Available | {current_user} [Idle]")
        return

    r = dict(rows[0])
    owner = r['owner']
    script = r['script_name']
    acquired_raw = r['acquired_at']
    
    try:
        acq = datetime.fromisoformat(acquired_raw)
        if acq.tzinfo is None:
            acq = acq.replace(tzinfo=timezone.utc)
        elapsed = (datetime.now(timezone.utc) - acq).total_seconds()
        elapsed_str = f"{int(elapsed//60)}m {int(elapsed%60)}s"
    except Exception:
        elapsed_str = "?"

    if owner == current_user:
        print(f"🔴 PT ACTIVE | {script} | {elapsed_str} elapsed")
    else:
        print(f"🟡 OCCUPIED | {script} | By: {owner} | since {elapsed_str}")

if __name__ == '__main__':
    main()
