#!/usr/bin/env python3
import sys, json, os

sys.path.append(os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'lib', 'python'))
from db import get_conn, init_db

def check():
    if not os.path.exists(os.path.expanduser('~/.pt/var/pt.db')):
        init_db()
    conn = get_conn()
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM users JOIN roles ON users.role_id = roles.id WHERE roles.name = 'god'")
    count = c.fetchone()[0]
    if count == 0:
        print("needs_bootstrap")
        sys.exit(0)
    print("ok")
    sys.exit(0)

if __name__ == '__main__':
    check()
