# ── Copy to local.env then edit. Do not commit local.env.
PT_RUNNER=docker-local-pt/scripts/k6-mock-runner.js
SUITE=Growin_PT_Dev[ToDo]
SCENARIO=BP001
PLATFORM=Web
VARIANT=original
ENV=LOCAL
RUNBY=LocalDocker
K6_USERS=1
USER_COUNT=1
DURATION=30s
NUMSTART=1
DEBUG=true
BP_CONFIG=
BP_CONFIG_FILE=/results/BP001.json
BASE_URL=http://mock-api:8080
STRICT_PLATFORM_IMPLEMENTATION=false
ALLOW_ANDROID_WEB_FALLBACK=true
THINK_TIME_JITTER=true
K6_INSECURE_SKIP_TLS_VERIFY=true
# K6_OUT only when observability profile + USE_GRAFANA_OUTPUT=true
# K6_OUT=influxdb=http://influxdb:8086/k6
USE_GRAFANA_OUTPUT=false
MOCK_LATENCY_MS=80
MOCK_ERROR_RATE=0

# Grafana (observability profile)
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
