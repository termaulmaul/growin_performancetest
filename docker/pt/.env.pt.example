# ───── PT Local Docker — example env (copy to .env.pt and edit) ─────
# Runner
PT_RUNNER=Script/Growin_PT_Dev[ToDo]/Growin_PT_Dev.js
SCENARIO=BP001
PLATFORM=Web
ENV=INT
RUNBY=LocalDocker
USER=1
DURATION=30s
NUMSTART=1
DEBUG=true

# Config source. Either set BP_CONFIG (raw JSON one-liner) or BP_CONFIG_FILE (YAML path; host pre-renders).
BP_CONFIG=
BP_CONFIG_FILE=Script/Growin_PT_Dev[ToDo]/Configs/BP001.yaml

# Compat flags
STRICT_PLATFORM_IMPLEMENTATION=false
ALLOW_ANDROID_WEB_FALLBACK=true

# Mock controls (only when --profile mock)
MOCK_STATUS=200
MOCK_LATENCY_MS=50

# k6 output sink. Empty = stdout only. Examples:
#   K6_OUT=json=summary.json
#   K6_OUT=influxdb=http://influxdb:8086/k6
K6_OUT=

# TLS — mock-api is http, but Helper/runner getBaseUrl() returns https. Enable to allow mock.
K6_INSECURE_SKIP_TLS_VERIFY=true

# Do NOT commit real credentials. Use real INT smoke only with `ENV=INT` and host network creds outside repo.
